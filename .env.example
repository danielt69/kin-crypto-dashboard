# Copy to .env (docker compose picks it up automatically) or export for native dev.
# No secrets live here: CoinGecko's /coins/markets endpoint requires NO API key.

# How often the server's single shared refresh loop polls CoinGecko.
# One upstream call per tick regardless of how many clients are connected.
REFRESH_INTERVAL_MS=20000

# --- docker compose ---
POSTGRES_USER=kin
POSTGRES_PASSWORD=kin
POSTGRES_DB=kin_crypto
API_PORT=3001   # host port for the API service
WEB_PORT=8080   # host port for the web frontend

# --- native dev (server reads this directly) ---
# Point at any local Postgres; the server creates its own tables on boot.
DATABASE_URL=postgres://kin:kin@localhost:5432/kin_crypto
PORT=3001
